# Memory Tree — Umgebungsvariablen
# Kopieren: cp .env.example .env und Werte anpassen

# Umgebung: "development" oder "production"
APP_ENV=production
DEBUG=false

# WICHTIG: Sicheren Schlüssel generieren mit:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=HIER_SICHEREN_KEY_SETZEN

# Erlaubte Hosts (kommagetrennt, * = alle)
# Für LAN: z.B. "192.168.1.100,memory-tree.local"
ALLOWED_HOSTS=*

# Datenbank (Pfad relativ zum Projektverzeichnis)
DATABASE_URL=sqlite:///./data/memory_tree.db

# JWT-Token-Lebensdauer
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Uploads
UPLOAD_DIR=data/uploads
MAX_IMAGE_SIZE=1920
MAX_UPLOAD_BYTES=10485760

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Rate Limiting für Login
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW=300
